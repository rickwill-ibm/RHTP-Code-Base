# ============================================================================
# TCOC Application — Environment Configuration Template
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env.local   (Mac/Linux)
#                       copy .env.example .env.local  (Windows)
#   2. Edit .env.local with your settings
#   3. Restart the dev server: npm run dev
#
# .env.local is gitignored (never committed) — this file IS committed.
# ============================================================================

# ============================================================================
# MASTER DATA SOURCE SWITCH
# ----------------------------------------------------------------------------
# true  = mock data, no FHIR server needed (safe default for first run)
# false = connect to live HAPI FHIR server (requires Docker running)
# ============================================================================
NEXT_PUBLIC_USE_MOCK_DATA=false

# ============================================================================
# FHIR SERVER
# ----------------------------------------------------------------------------
# After cloning, start the local FHIR server:
#   docker compose -f fhir/docker-compose.yml up -d
# Then seed patient data:
#   node fhir/migrate-patients.mjs
# ============================================================================
NEXT_PUBLIC_FHIR_BASE_URL=http://localhost:8080/fhir
NEXT_PUBLIC_FHIR_TIMEOUT=30000
NEXT_PUBLIC_FHIR_RETRY_ATTEMPTS=3

# ============================================================================
# SMART ON FHIR (OAuth 2.0) — leave as-is for local dev
# ============================================================================
NEXT_PUBLIC_SMART_CLIENT_ID=tcoc-client
NEXT_PUBLIC_SMART_REDIRECT_URI=http://localhost:4029/md-smart-launch
NEXT_PUBLIC_SMART_SCOPE=launch launch/patient patient/*.read openid fhirUser offline_access

# ============================================================================
# CDS HOOKS
# ============================================================================
NEXT_PUBLIC_ENABLE_CDS_HOOKS=true
NEXT_PUBLIC_CDS_HOOKS_ENDPOINT=http://localhost:8080/cds-services
NEXT_PUBLIC_CDS_HOOKS_TIMEOUT=10000

# ============================================================================
# FEATURE FLAGS
# ============================================================================
NEXT_PUBLIC_ENABLE_REAL_TIME_UPDATES=false
NEXT_PUBLIC_ENABLE_AUDIT_LOGGING=false
NEXT_PUBLIC_ENABLE_MCP_TOOLS=false

# ============================================================================
# DEVELOPER / DEBUG
# ============================================================================
NEXT_PUBLIC_ENABLE_DEBUG_LOGGING=true
NEXT_PUBLIC_SHOW_DATA_SOURCE_INDICATOR=true
