# Standalone SMART App Configuration

# Mock data mode (no backend required)
NEXT_PUBLIC_USE_MOCK_DATA=true

# FHIR Server (optional - only needed if connecting to real FHIR server)
NEXT_PUBLIC_FHIR_BASE_URL=http://localhost:8080/fhir

# SMART on FHIR Configuration
NEXT_PUBLIC_SMART_CLIENT_ID=standalone-smart-app
NEXT_PUBLIC_ENABLE_CDS_HOOKS=true

# Application Settings
NEXT_PUBLIC_APP_NAME=SMART App - Care Gap Closure
NEXT_PUBLIC_APP_VERSION=1.0.0