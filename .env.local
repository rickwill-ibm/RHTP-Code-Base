# TCOC Application Configuration
# Copy this file to .env.local and configure for your environment

# ============================================================================
# CRITICAL: GLOBAL DATA SOURCE SWITCH
# ============================================================================
# This is the master switch that controls whether the ENTIRE application
# uses mock data or connects to live FHIR systems.
# 
# Set to 'true' for demonstrations without a live FHIR server
# Set to 'false' to connect to real FHIR backend
# ============================================================================
NEXT_PUBLIC_USE_MOCK_DATA=false

# ============================================================================
# FHIR SERVER CONFIGURATION
# ============================================================================
# Base URL for the FHIR R4 server (HAPI FHIR or other)
NEXT_PUBLIC_FHIR_BASE_URL=http://localhost:8080/fhir

# FHIR request timeout in milliseconds
NEXT_PUBLIC_FHIR_TIMEOUT=30000

# Number of retry attempts for failed FHIR requests
NEXT_PUBLIC_FHIR_RETRY_ATTEMPTS=3

# ============================================================================
# SMART ON FHIR CONFIGURATION
# ============================================================================
# OAuth 2.0 client ID registered with the FHIR server
NEXT_PUBLIC_SMART_CLIENT_ID=tcoc-client

# OAuth 2.0 redirect URI (must match registration)
NEXT_PUBLIC_SMART_REDIRECT_URI=http://localhost:3000/md-smart-launch

# SMART scopes (space-separated)
NEXT_PUBLIC_SMART_SCOPE=launch launch/patient patient/*.read openid fhirUser offline_access

# SMART issuer URL (optional - for standalone launch)
# NEXT_PUBLIC_SMART_ISS=http://localhost:8080/fhir

# SMART launch token (optional - for EHR launch)
# NEXT_PUBLIC_SMART_LAUNCH=

# ============================================================================
# CDS HOOKS CONFIGURATION
# ============================================================================
# Enable CDS Hooks integration
NEXT_PUBLIC_ENABLE_CDS_HOOKS=true

# CDS Hooks discovery endpoint
NEXT_PUBLIC_CDS_HOOKS_ENDPOINT=http://localhost:8080/cds-services

# CDS Hooks request timeout in milliseconds
NEXT_PUBLIC_CDS_HOOKS_TIMEOUT=10000

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable real-time updates via Server-Sent Events
NEXT_PUBLIC_ENABLE_REAL_TIME_UPDATES=false

# Enable audit logging for compliance
NEXT_PUBLIC_ENABLE_AUDIT_LOGGING=false

# Enable MCP tools for AI agents
NEXT_PUBLIC_ENABLE_MCP_TOOLS=false

# ============================================================================
# MODULE-SPECIFIC OVERRIDES (OPTIONAL)
# ============================================================================
# These allow you to override the global NEXT_PUBLIC_USE_MOCK_DATA setting
# for specific modules. If not set, modules inherit the global setting.
# 
# Uncomment and set to 'true' to force a module to use mock data
# even when NEXT_PUBLIC_USE_MOCK_DATA=false
# ============================================================================

# Contract/Program Selection module
# NEXT_PUBLIC_CONTRACTS_USE_MOCK_DATA=true

# Financial Dashboard module
# NEXT_PUBLIC_FINANCIAL_USE_MOCK_DATA=true

# Panel/Cohort View module
# NEXT_PUBLIC_PANEL_USE_MOCK_DATA=true

# Patient Detail module
# NEXT_PUBLIC_PATIENT_DETAIL_USE_MOCK_DATA=true

# Provider Selection module
# NEXT_PUBLIC_PROVIDERS_USE_MOCK_DATA=true

# Referral Tracking module
# NEXT_PUBLIC_REFERRALS_USE_MOCK_DATA=true

# Quality Measures (STARS/HEDIS/MIPS) module
# NEXT_PUBLIC_QUALITY_USE_MOCK_DATA=true

# SMART Launch module
# NEXT_PUBLIC_SMART_LAUNCH_USE_MOCK_DATA=true

# ============================================================================
# DEVELOPMENT CONFIGURATION
# ============================================================================
# Enable debug logging in browser console
NEXT_PUBLIC_ENABLE_DEBUG_LOGGING=true

# Show data source indicator in UI (Mock vs Live)
NEXT_PUBLIC_SHOW_DATA_SOURCE_INDICATOR=true

# ============================================================================
# DEMONSTRATION PRESETS
# ============================================================================
# Quick configuration presets for common scenarios:
#
# DEMO MODE (No FHIR server required):
#   NEXT_PUBLIC_USE_MOCK_DATA=false
#   NEXT_PUBLIC_ENABLE_CDS_HOOKS=true (uses mock CDS responses)
#
# DEVELOPMENT MODE (Local FHIR server):
#   NEXT_PUBLIC_USE_MOCK_DATA=false
#   NEXT_PUBLIC_FHIR_BASE_URL=http://localhost:8080/fhir
#   NEXT_PUBLIC_ENABLE_CDS_HOOKS=true
#
# PRODUCTION MODE (Live FHIR server):
#   NEXT_PUBLIC_USE_MOCK_DATA=false
#   NEXT_PUBLIC_FHIR_BASE_URL=https://fhir.example.com/fhir
#   NEXT_PUBLIC_ENABLE_CDS_HOOKS=true
#   NEXT_PUBLIC_ENABLE_AUDIT_LOGGING=true
# ============================================================================